# API
APP_PORT=8000
LOG_LEVEL=INFO

# Auth
MASTER_TOKEN=change-me

# LLM Provider
OPENROUTER_API_KEY=sk-or-...

# Guardrails
GUARDRAILS_ENABLED=true

# Langfuse
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Langfuse internal (for docker-compose)
LANGFUSE_DATABASE_URL=postgresql://langfuse:langfuse@langfuse-db:5432/langfuse
LANGFUSE_NEXTAUTH_SECRET=change-me-nextauth-secret
LANGFUSE_NEXTAUTH_URL=http://localhost:3001
LANGFUSE_SALT=change-me-salt
